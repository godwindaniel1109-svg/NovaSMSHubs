# NovaSMSHub Production Environment Configuration
# Copy this file to .env.production for production deployment

# API Configuration
REACT_APP_API_URL=https://api.novasmshub.com/api
REACT_APP_ADMIN_API_URL=https://admin-api.novasmshub.com/api/admin
REACT_APP_WS_URL=wss://api.novasmshub.com/ws

# Payment Gateway Configuration
REACT_APP_PAYSTACK_PUBLIC_KEY=pk_live_1360357981b26244290e833fb700ea775063618b
REACT_APP_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Application Configuration
REACT_APP_NAME=NovaSMSHub
REACT_APP_VERSION=2.0.0
REACT_APP_DESCRIPTION=Virtual Phone Numbers for SMS Verification

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_ERROR_TRACKING=true
REACT_APP_ENABLE_PERFORMANCE_MONITORING=true

# Security Configuration
REACT_APP_ENABLE_CSP=true
REACT_APP_SESSION_TIMEOUT=3600000
REACT_APP_MAX_LOGIN_ATTEMPTS=5

# Rate Limiting
REACT_APP_API_RATE_LIMIT=100
REACT_APP_API_RATE_WINDOW=60000

# Cache Configuration
REACT_APP_CACHE_TTL=300000
REACT_APP_ENABLE_SERVICE_WORKER=true

# Monitoring and Analytics
REACT_APP_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
REACT_APP_GA_TRACKING_ID=GA-XXXXXXXX-X

# External Services
REACT_APP_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
REACT_APP_SUPPORT_EMAIL=support@novasmshub.com
REACT_APP_SUPPORT_PHONE=+2348000000000

# Business Configuration
REACT_APP_CURRENCY=NGN
REACT_APP_DEFAULT_COUNTRY=NG
REACT_APP_MIN_FUND_AMOUNT=100
REACT_APP_MAX_FUND_AMOUNT=1000000

# SMS Configuration
REACT_APP_SMS_TIMEOUT=300000
REACT_APP_SMS_RETRY_ATTEMPTS=3
REACT_APP_ORDER_EXPIRY_TIME=900000

# UI Configuration
REACT_APP_THEME=light
REACT_APP_PRIMARY_COLOR=#FFD700
REACT_APP_SECONDARY_COLOR=#FFA500
REACT_APP_NAVY_COLOR=#1e3a8a

# Development Tools (disabled in production)
GENERATE_SOURCEMAP=false
REACT_APP_DEBUG=false

# Google OAuth
REACT_APP_GOOGLE_CLIENT_ID=571690553766-0il1qd53kmuagr6f70a00fa3bkrm2k8g.apps.googleusercontent.com
